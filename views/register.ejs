<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Velox | Create Account</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

    <div class="auth-fullpage-wrapper">
        <!-- Spans completely across Left half -->
        <div class="auth-sidebar">
            <div class="sidebar-logo">VELOX<span>.</span></div>
            <div class="sidebar-content">
                <h1>Join the <br>Movement.</h1>
                <p>Unlock early premium shoe drops, trace orders easily, and experience lightning checkout workflows.</p>
            </div>
            <div></div>
        </div>

        <!-- Spans completely across Right half -->
        <div class="auth-form-panel">
            <h2>Join Velox</h2>
            <p class="subtitle">Create an account to start your journey</p>
            
            <form action="/users/register" method="POST" class="auth-form">
                <div class="input-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" placeholder="John Doe" required>
                </div>

                <div class="input-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="example@velox.com" required>
                </div>
                
                <div class="input-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="Minimum 8 characters" required>
                </div>


                <button type="submit" class="auth-submit-btn">Create Account</button>
            </form>

            <p class="auth-switch">Already have an account? <a href="/users/login">Log in</a></p>
        </div>
    </div>

</body>
</html>